rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Imagens de produtos — leitura pública, upload só admin
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'gerente'];
    }
    
    // Avatares de usuários — leitura pública, upload só dono
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Comprovantes de pagamento — só dono e admin
    match /comprovantes/{orderId}/{allPaths=**} {
      allow read: if request.auth != null && (
        firestore.get(/databases/(default)/documents/orders/$(orderId)).data.clienteUid == request.auth.uid ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'gerente']
      );
      allow write: if request.auth != null;
    }
    
    // Demais arquivos — bloqueados por padrão
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}